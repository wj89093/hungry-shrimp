{
  "name": "hungry-shrimp",
  "version": "1.0.0",
  "description": "Multi-Agent Snake Battle Arena",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:next\" \"npm run dev:server\"",
    "dev:next": "next dev --port 3002",
    "dev:server": "tsx watch server/index.ts",
    "build": "next build",
    "start": "next start --port 3002",
    "start:server": "NODE_ENV=production tsx server/index.ts",
    "start:prod": "NODE_ENV=production tsx server-express.ts",
    "start:server:dist": "NODE_ENV=production node dist/server/index.js",
    "db:init": "tsx server/db-init.ts"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "http-proxy-middleware": "^3.0.5",
    "next": "^16.2.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "ws": "^8.18.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.5.14",
    "concurrently": "^9.1.2",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.0.0"
  }
}
